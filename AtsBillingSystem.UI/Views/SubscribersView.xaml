<UserControl x:Class="AtsBillingSystem.UI.Views.SubscribersView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:viewmodels="clr-namespace:AtsBillingSystem.UI.ViewModels"
             mc:Ignorable="d" 
             d:DataContext="{d:DesignInstance Type=viewmodels:SubscribersViewModel}"
             d:DesignHeight="600" d:DesignWidth="900"
             Background="Transparent">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
    </UserControl.Resources>

    <Grid Background="{DynamicResource BackgroundColor}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="{DynamicResource SurfaceColor}" Padding="20" 
                BorderBrush="{DynamicResource DividerColor}" BorderThickness="0,0,0,1">
            <WrapPanel Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="Абоненты" FontSize="20" FontWeight="SemiBold" 
                           Foreground="{DynamicResource TextColor}" Margin="0,0,30,0"
                           VerticalAlignment="Center"/>

                <TextBlock Text="Загрузка..." Margin="0,0,20,0" 
                           Foreground="{DynamicResource PrimaryColor}"
                           VerticalAlignment="Center"
                           Visibility="{Binding IsLoading, Converter={StaticResource BooleanToVisibilityConverter}}"/>
            </WrapPanel>
        </Border>

        <DataGrid Grid.Row="1" 
                  ItemsSource="{Binding Subscribers}" 
                  AutoGenerateColumns="False" 
                  CanUserAddRows="False"
                  CanUserDeleteRows="False"
                  IsReadOnly="True"
                  HeadersVisibility="Column"
                  GridLinesVisibility="Horizontal"
                  HorizontalGridLinesBrush="{DynamicResource DividerColor}"
                  Background="{DynamicResource SurfaceColor}"
                  BorderThickness="0"
                  RowHeight="40"
                  Margin="20">

            <DataGrid.ColumnHeaderStyle>
                <Style TargetType="DataGridColumnHeader">
                    <Setter Property="Background" Value="{DynamicResource SurfaceColor}"/>
                    <Setter Property="Foreground" Value="#757575"/>
                    <Setter Property="FontWeight" Value="SemiBold"/>
                    <Setter Property="Padding" Value="10,0"/>
                    <Setter Property="Height" Value="40"/>
                    <Setter Property="BorderThickness" Value="0,0,0,1"/>
                    <Setter Property="BorderBrush" Value="{DynamicResource DividerColor}"/>
                </Style>
            </DataGrid.ColumnHeaderStyle>

            <DataGrid.Columns>
                <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="80"/>
                <DataGridTextColumn Header="Номер телефона" Binding="{Binding PhoneNumber}" Width="150"/>
                <DataGridTextColumn Header="ФИО / Название" Binding="{Binding FullName}" Width="*"/>

                <DataGridTextColumn Header="Баланс" Binding="{Binding Balance, StringFormat=\{0:C2\}}" Width="120">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="HorizontalAlignment" Value="Right"/>
                            <Setter Property="Margin" Value="0,0,10,0"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
            </DataGrid.Columns>
        </DataGrid>

        <Border Grid.Row="2" Background="{DynamicResource SurfaceColor}" Padding="15"
                BorderBrush="{DynamicResource DividerColor}" BorderThickness="0,1,0,0">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">

                <Button Content="Назад" 
                        Command="{Binding PreviousPageCommand}"
                        Style="{DynamicResource MaterialButtonStyle}"
                        Padding="15,5" Margin="0,0,10,0"/>

                <TextBlock VerticalAlignment="Center" Margin="10,0" Foreground="{DynamicResource TextColor}">
                    <Run Text="Страница "/>
                    <Run Text="{Binding CurrentPage, Mode=OneWay}"/>
                    <Run Text=" из "/>
                    <Run Text="{Binding TotalPages, Mode=OneWay}"/>
                </TextBlock>

                <Button Content="Вперед" 
                        Command="{Binding NextPageCommand}"
                        Style="{DynamicResource MaterialButtonStyle}"
                        Padding="15,5" Margin="10,0,0,0"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>