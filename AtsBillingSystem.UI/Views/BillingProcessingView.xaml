<UserControl x:Class="AtsBillingSystem.UI.Views.BillingProcessingView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:viewmodels="clr-namespace:AtsBillingSystem.UI.ViewModels"
             mc:Ignorable="d" 
             d:DataContext="{d:DesignInstance Type=viewmodels:BillingProcessingViewModel}"
             d:DesignHeight="450" d:DesignWidth="800"
             Background="Transparent">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
    </UserControl.Resources>

    <Grid>
        <Border Background="{DynamicResource SurfaceColor}" 
                CornerRadius="8" 
                Padding="40"
                HorizontalAlignment="Center" 
                VerticalAlignment="Center"
                MinHeight="250" MinWidth="450">
            <Border.Effect>
                <DropShadowEffect Color="Black" Opacity="0.1" BlurRadius="10" ShadowDepth="2"/>
            </Border.Effect>

            <StackPanel>
                <TextBlock Text="Импорт биллинга (CDR)" 
                           FontSize="24" 
                           FontWeight="SemiBold" 
                           Foreground="{DynamicResource TextColor}"
                           HorizontalAlignment="Center" 
                           Margin="0,0,0,30"/>

                <TextBlock Text="{Binding StatusMessage}" 
                           FontSize="14" 
                           Foreground="#757575"
                           HorizontalAlignment="Center" 
                           TextWrapping="Wrap"
                           TextAlignment="Center"
                           Margin="0,0,0,15"/>

                <ProgressBar Value="{Binding ProgressBarValue}" 
                             Height="6" 
                             Minimum="0" Maximum="100"
                             Margin="0,0,0,25"
                             BorderThickness="0"
                             Foreground="{DynamicResource PrimaryColor}"
                             Visibility="{Binding IsProcessing, Converter={StaticResource BooleanToVisibilityConverter}}"/>

                <Button Content="Выбрать CSV файл" 
                        Command="{Binding SelectFileAndExecuteAsyncCommand}"
                        Style="{DynamicResource MaterialButtonStyle}"
                        Width="200" Height="40"
                        HorizontalAlignment="Center"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>