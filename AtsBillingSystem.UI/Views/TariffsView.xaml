<UserControl x:Class="AtsBillingSystem.UI.Views.TariffsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:viewmodels="clr-namespace:AtsBillingSystem.UI.ViewModels"
             Background="Transparent">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Orientation="Horizontal" Margin="20">
            <TextBlock Text="Доступные тарифы" FontSize="20" FontWeight="SemiBold" Margin="0,0,20,0"/>
            <Button Content="Обновить" Command="{Binding LoadTariffsCommand}" Padding="15,5"/>
        </StackPanel>

        <DataGrid Grid.Row="1" ItemsSource="{Binding Tariffs}" AutoGenerateColumns="False" 
                  IsReadOnly="True" Margin="20">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Название" Binding="{Binding Name}" Width="*"/>
                <DataGridTextColumn Header="Внутри сети" Binding="{Binding InternalMinutePrice}" Width="100"/>
                <DataGridTextColumn Header="Город" Binding="{Binding CityMinutePrice}" Width="100"/>
                <DataGridTextColumn Header="Абон. плата" Binding="{Binding SubscriptionFee}" Width="120"/>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</UserControl>