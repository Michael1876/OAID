<UserControl x:Class="AtsBillingSystem.UI.Views.SubscriberEditorView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="Transparent">
    <Grid>
        <Border Background="{DynamicResource SurfaceColor}" CornerRadius="8" Padding="30"
                HorizontalAlignment="Center" VerticalAlignment="Center" MinWidth="500">
            <Border.Effect>
                <DropShadowEffect Color="Black" Opacity="0.1" BlurRadius="10" ShadowDepth="2"/>
            </Border.Effect>

            <StackPanel>
                <TextBlock Text="Карточка абонента" FontSize="22" FontWeight="SemiBold" Margin="0,0,0,20" HorizontalAlignment="Center"/>

                <TextBlock Text="Полное имя / Название организации" Margin="0,0,0,5" Foreground="#757575"/>
                <TextBox Text="{Binding EditingSubscriber.FullName, UpdateSourceTrigger=PropertyChanged}" Padding="8" Margin="0,0,0,15"/>

                <TextBlock Text="Номер договора" Margin="0,0,0,5" Foreground="#757575"/>
                <TextBox Text="{Binding EditingSubscriber.ContractNumber, UpdateSourceTrigger=PropertyChanged}" Padding="8" Margin="0,0,0,15"/>

                <TextBlock Text="Номер телефона" Margin="0,0,0,5" Foreground="#757575"/>
                <TextBox Text="{Binding EditingSubscriber.PhoneNumber, UpdateSourceTrigger=PropertyChanged}" Padding="8" Margin="0,0,0,15"/>

                <TextBlock Text="Текущий баланс (₽)" Margin="0,0,0,5" Foreground="#757575"/>
                <TextBox Text="{Binding EditingSubscriber.Balance, StringFormat=\{0:F2\}, UpdateSourceTrigger=PropertyChanged}" Padding="8" Margin="0,0,0,15"/>

                <TextBlock Text="Тарифный план" Margin="0,0,0,5" Foreground="#757575"/>
                <ComboBox ItemsSource="{Binding Tariffs}" 
                          SelectedValue="{Binding EditingSubscriber.TariffId}" 
                          SelectedValuePath="Id" 
                          DisplayMemberPath="Name" 
                          Padding="8" Margin="0,0,0,25"/>

                <CheckBox IsChecked="{Binding EditingSubscriber.IsActive}" Content="Статус: Активен" Margin="0,0,0,25" FontWeight="SemiBold"/>

                <UniformGrid Columns="2" Rows="1">
                    <Button Content="Отмена" Command="{Binding CancelCommand}" Background="#9E9E9E" Style="{DynamicResource MaterialButtonStyle}" Margin="0,0,10,0"/>
                    <Button Content="Сохранить" Command="{Binding SaveAsyncCommand}" Style="{DynamicResource MaterialButtonStyle}" Margin="10,0,0,0"/>
                </UniformGrid>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>