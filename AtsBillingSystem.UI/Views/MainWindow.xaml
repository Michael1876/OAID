<Window x:Class="AtsBillingSystem.UI.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:viewmodels="clr-namespace:AtsBillingSystem.UI.ViewModels"
        xmlns:views="clr-namespace:AtsBillingSystem.UI.Views"
        Title="Система биллинга АТС" Height="720" Width="1080"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource BackgroundColor}">

    <Window.Resources>
        <!-- Маппинг ViewModel -> View. WPF сам отрисует нужную View в ContentControl -->
        <DataTemplate DataType="{x:Type viewmodels:BillingProcessingViewModel}">
            <views:BillingProcessingView />
        </DataTemplate>

        <DataTemplate DataType="{x:Type viewmodels:SubscribersViewModel}">
            <views:SubscribersView />
        </DataTemplate>

        <DataTemplate DataType="{x:Type viewmodels:CallLogViewModel}">
            <views:CallLogView />
        </DataTemplate>

        <DataTemplate DataType="{x:Type viewmodels:TariffsViewModel}">
            <views:TariffsView />
        </DataTemplate>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <!-- Боковое меню -->
            <ColumnDefinition Width="250" />
            <!-- Основная область контента -->
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="{DynamicResource SurfaceColor}" 
                BorderBrush="{DynamicResource DividerColor}" BorderThickness="0,0,1,0">
            <StackPanel Margin="0,20,0,0">
                <TextBlock Text="АТС Биллинг" FontSize="20" FontWeight="Bold" 
                           Foreground="{DynamicResource PrimaryColor}" 
                           Margin="24,0,0,30"/>

                <Button Content="Абоненты" 
                        Style="{DynamicResource MenuButtonStyle}"
                        Command="{Binding NavigateToSubscribersCommand}"/>

                <Button Content="Тарифы" 
                        Style="{DynamicResource MenuButtonStyle}"
                        Command="{Binding NavigateToTariffsCommand}"/>

                <Button Content="Журнал звонков" 
                        Style="{DynamicResource MenuButtonStyle}"
                        Command="{Binding NavigateToCallLogCommand}"/>

                <Button Content="Импорт биллинга" 
                        Style="{DynamicResource MenuButtonStyle}"
                        Command="{Binding NavigateToBillingCommand}"/>
            </StackPanel>
        </Border>

        <!-- Область, которая динамически меняется в зависимости от свойства CurrentViewModel -->
        <Grid Grid.Column="1" Margin="20">
            <ContentControl Content="{Binding CurrentViewModel}" />
        </Grid>
    </Grid>
</Window>